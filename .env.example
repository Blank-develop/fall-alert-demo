# --- Telegram ---
# 1. Open Telegram, search @BotFather, send /newbot, follow prompts -> copy the token here.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# 2. Get your chat id: message your new bot once (say "hi"), then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    Find "chat":{"id":<NUMBER>} and paste it below.
#    (For a group: add the bot to the group, send a message, the id will be negative.)
TELEGRAM_CHAT_ID=123456789

# --- Server ---
PORT=3000

# Optional label shown in the alert (e.g. "Ward 3 Camera", "Front Door")
CAMERA_LABEL=Demo Camera (Phone)
